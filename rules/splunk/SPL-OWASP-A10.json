{
  "rule_id": "SPL-OWASP-A10",
  "rule_name": "Server-Side Request Forgery (SSRF) Attempt",
  "description": "Detects attempts to exploit SSRF vulnerabilities by monitoring requests to internal IP addresses or localhost.",
  "severity": "Critical",
  "owasp_category": "A10:2021-Server-Side Request Forgery (SSRF)",
  "search_query": "index=main sourcetype=_json _index_earliest=-2m (\"*localhost*\" OR \"*127.0.0.1*\" OR \"*169.254.169.254*\" OR \"*.internal*\")"
}
